<UserControl x:Class="UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:views="clr-namespace:UI.Views"
             xmlns:local="clr-namespace:UI"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="900"
             Background="{DynamicResource MainBackgroundBrush}">

    <UserControl.Resources>
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="10"/>
            <Setter Property="Background" Value="{DynamicResource TrackBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="Root">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5"/>
                            <Border HorizontalAlignment="Left" CornerRadius="5" Background="{TemplateBinding Foreground}">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                        <Binding Path="Value" RelativeSource="{RelativeSource TemplatedParent}"/>
                                        <Binding Path="ActualWidth" ElementName="Root"/>
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section label inside platform cards -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,20,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===================== HERO BANNER ===================== -->
        <Border Grid.Row="0" CornerRadius="18" Padding="26,22" Margin="0,0,0,20"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#141A20" Offset="0"/>
                    <GradientStop Color="#10242B" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="MINER STATUS" Style="{StaticResource SectionLabel}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Ellipse Width="14" Height="14" Fill="#FFB020" VerticalAlignment="Center" Margin="0,0,12,0">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#FFB020" BlurRadius="14" ShadowDepth="0" Opacity="0.8"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock x:Name="MinerStatusText"
                                   Text="{Binding MinerStatus, FallbackValue=Active}"
                                   Foreground="#FFB020" FontSize="34" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBlock x:Name="MinerStatusDetailsText"
                               Text="{Binding MinerStatusDetails, FallbackValue=Waiting...}"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="13" Margin="26,2,0,0"/>
                </StackPanel>

                <!-- Connections + Login -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,12">
                        <!-- Twitch pill -->
                        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="20" Padding="12,7" Margin="0,0,8,0"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="9" Height="9" Fill="{Binding TwitchConnectionColor, FallbackValue=Red}" VerticalAlignment="Center"/>
                                <TextBlock Text="Twitch" Margin="8,0,6,0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource TwitchBrush}"/>
                                <TextBlock Text="{Binding TwitchConnectionStatus, FallbackValue=Disconnected}" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                        </Border>
                        <!-- Kick pill -->
                        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="20" Padding="12,7"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="9" Height="9" Fill="{Binding KickConnectionColor, FallbackValue=Red}" VerticalAlignment="Center"/>
                                <TextBlock Text="Kick" Margin="8,0,6,0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource KickBrush}"/>
                                <TextBlock Text="{Binding KickConnectionStatus, FallbackValue=Disconnected}" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="KickLoginButton" Content="Login Kick" Width="120" Height="36" Margin="0,0,10,0"
                                FontWeight="SemiBold" Cursor="Hand" Click="OnKickLoginClick">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="#2D9D78" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.Foreground="White"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#34B48F"/>
                                            <Setter TargetName="border" Property="Effect">
                                                <Setter.Value><DropShadowEffect Color="#34B48F" Opacity="0.5" BlurRadius="10" ShadowDepth="0"/></Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#257A63"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="border" Property="Background" Value="#333333"/>
                                            <Setter Property="Foreground" Value="#888888"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="TwitchLoginButton" Content="Login Twitch" Width="120" Height="36"
                                FontWeight="SemiBold" Cursor="Hand" Click="OnTwitchLoginClick">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="#9146FF" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.Foreground="White"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#A970FF"/>
                                            <Setter TargetName="border" Property="Effect">
                                                <Setter.Value><DropShadowEffect Color="#A970FF" Opacity="0.5" BlurRadius="12" ShadowDepth="0"/></Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#772CE8"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="border" Property="Background" Value="#333333"/>
                                            <Setter Property="Foreground" Value="#888888"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===================== PLATFORM CARDS ===================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== TWITCH CARD ===== -->
            <Border Grid.Column="0" Margin="0,0,10,0" CornerRadius="16" Padding="0"
                    Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <DockPanel>
                    <Border DockPanel.Dock="Top" CornerRadius="16,16,0,0" Padding="20,16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#2A1A4A" Offset="0"/>
                                <GradientStop Color="#181C22" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="4" Height="22" CornerRadius="2" Background="{DynamicResource TwitchBrush}" Margin="0,0,12,0"/>
                            <TextBlock Text="Twitch" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16,20,20">
                        <StackPanel>
                            <!-- Campaign -->
                            <TextBlock Text="CAMPAIGN" Style="{StaticResource SectionLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                               Visibility="{Binding TwitchCampaignName, Converter={StaticResource StringToVisibilityConverter}}">
                                <Border Width="34" Height="44" CornerRadius="6" ClipToBounds="True"
                                        Background="{DynamicResource MainBackgroundBrush}" Margin="0,0,10,0"
                                        Visibility="{Binding TwitchCampaignImageUrl, Converter={StaticResource StringToVisibilityConverter}}">
                                    <Image local:ImageEx.SourceUrl="{Binding TwitchCampaignImageUrl}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                                <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                           Text="{Binding TwitchCampaignName}" FontWeight="SemiBold" FontSize="14"
                                           Foreground="{DynamicResource TwitchBrush}"/>
                            </StackPanel>

                            <Grid Margin="0,12,0,0">
                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding TwitchCampaignProgress}"/>
                                <TextBlock Text="{Binding TwitchCampaignProgress, StringFormat='{}{0}%'}" HorizontalAlignment="Right" Margin="0,-18,0,0"
                                           FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Grid>

                            <!-- Drop -->
                            <TextBlock Text="CURRENT DROP" Style="{StaticResource SectionLabel}" Margin="0,18,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                               Visibility="{Binding TwitchDropName, Converter={StaticResource StringToVisibilityConverter}}">
                                <Border Width="30" Height="30" CornerRadius="6" ClipToBounds="True"
                                        Background="{DynamicResource MainBackgroundBrush}" Margin="0,0,10,0"
                                        Visibility="{Binding TwitchDropImageUrl, Converter={StaticResource StringToVisibilityConverter}}">
                                    <Image local:ImageEx.SourceUrl="{Binding TwitchDropImageUrl}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                                <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                           Text="{Binding TwitchDropName}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>

                            <Grid Margin="0,12,0,0">
                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding TwitchDropProgress}"/>
                                <TextBlock Text="{Binding TwitchDropProgress, StringFormat='{}{0}%'}" HorizontalAlignment="Right" Margin="0,-18,0,0"
                                           FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Grid>

                            <!-- Watching + online -->
                            <TextBlock Margin="0,16,0,0" Visibility="{Binding TwitchWatchedChannel, Converter={StaticResource StringToVisibilityConverter}}">
                                <Run Text="Watching: " Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <Run Text="{Binding TwitchWatchedChannel}" FontWeight="SemiBold" Foreground="{DynamicResource TwitchBrush}"/>
                                <Run Text="  "/><Run FontWeight="SemiBold">
                                    <Run.Style>
                                        <Style TargetType="Run">
                                            <Setter Property="Text" Value=""/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TwitchStreamOnlineStatus}" Value="online">
                                                    <Setter Property="Text" Value="● online"/><Setter Property="Foreground" Value="#00E676"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding TwitchStreamOnlineStatus}" Value="offline">
                                                    <Setter Property="Text" Value="● offline"/><Setter Property="Foreground" Value="#FF5252"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Run.Style>
                                </Run>
                            </TextBlock>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0"
                                        Visibility="{Binding TwitchWatchedChannel, Converter={StaticResource StringToVisibilityConverter}}">
                                <Button Content="Switch" Click="OnSwitchTwitchStreamerClick" Style="{StaticResource AccentButtonStyle}" Padding="12,6" Margin="0,0,8,0"/>
                                <TextBox x:Name="TwitchStreamerInput" Width="110" VerticalContentAlignment="Center" ToolTip="Channel name or URL"/>
                                <Button Content="Check" Click="OnCheckTwitchStreamerClick" Style="{StaticResource AccentButtonStyle}" Padding="12,6" Margin="8,0,0,0"/>
                                <Button Content="Set" Click="OnSetTwitchStreamerClick" Style="{StaticResource AccentButtonStyle}" Padding="12,6" Margin="8,0,0,0"/>
                            </StackPanel>

                            <TextBlock Text="{Binding TwitchStreamerCheckResult}" TextWrapping="Wrap" Margin="0,8,0,0"
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Visibility="{Binding TwitchStreamerCheckResult, Converter={StaticResource StringToVisibilityConverter}}"/>

                            <!-- Also earning -->
                            <StackPanel Margin="0,16,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TwitchAlsoMining.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="ALSO EARNING ON THIS CHANNEL" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                                <ItemsControl ItemsSource="{Binding TwitchAlsoMining}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,6,0,0">
                                                <TextBlock Text="{Binding Name, Mode=OneWay}" FontWeight="SemiBold" FontSize="12"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                <ItemsControl ItemsSource="{Binding Drops}" Margin="8,2,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,3,0,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Border Grid.Column="0" Width="20" Height="20" CornerRadius="3" ClipToBounds="True" Margin="0,0,8,0"
                                                                        Background="{DynamicResource MainBackgroundBrush}" VerticalAlignment="Center">
                                                                    <Image local:ImageEx.SourceUrl="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                                                </Border>
                                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                    <TextBlock TextTrimming="CharacterEllipsis" FontSize="11">
                                                                        <Run Text="{Binding Percent, Mode=OneWay}" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                                                                        <Run Text="% " Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                                                                        <Run Text="{Binding Name, Mode=OneWay}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                                    </TextBlock>
                                                                    <ProgressBar Value="{Binding Percent, Mode=OneWay}" Maximum="100" Height="4" Margin="0,2,0,0"
                                                                                 Foreground="{DynamicResource AccentBrush}" Background="{DynamicResource TrackBrush}"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- ===== KICK CARD ===== -->
            <Border Grid.Column="1" Margin="10,0,0,0" CornerRadius="16" Padding="0"
                    Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <DockPanel>
                    <Border DockPanel.Dock="Top" CornerRadius="16,16,0,0" Padding="20,16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#173A14" Offset="0"/>
                                <GradientStop Color="#181C22" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="4" Height="22" CornerRadius="2" Background="{DynamicResource KickBrush}" Margin="0,0,12,0"/>
                            <TextBlock Text="Kick" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16,20,20">
                        <StackPanel>
                            <!-- Campaign -->
                            <TextBlock Text="CAMPAIGN" Style="{StaticResource SectionLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                               Visibility="{Binding KickCampaignName, Converter={StaticResource StringToVisibilityConverter}}">
                                <Border Width="34" Height="44" CornerRadius="6" ClipToBounds="True"
                                        Background="{DynamicResource MainBackgroundBrush}" Margin="0,0,10,0"
                                        Visibility="{Binding KickCampaignImageUrl, Converter={StaticResource StringToVisibilityConverter}}">
                                    <Image local:ImageEx.SourceUrl="{Binding KickCampaignImageUrl}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                                <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                           Text="{Binding KickCampaignName}" FontWeight="SemiBold" FontSize="14"
                                           Foreground="{DynamicResource KickBrush}"/>
                            </StackPanel>

                            <Grid Margin="0,12,0,0">
                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding KickCampaignProgress}"/>
                                <TextBlock Text="{Binding KickCampaignProgress, StringFormat='{}{0}%'}" HorizontalAlignment="Right" Margin="0,-18,0,0"
                                           FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Grid>

                            <!-- Drop -->
                            <TextBlock Text="CURRENT DROP" Style="{StaticResource SectionLabel}" Margin="0,18,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                               Visibility="{Binding KickDropName, Converter={StaticResource StringToVisibilityConverter}}">
                                <Border Width="30" Height="30" CornerRadius="6" ClipToBounds="True"
                                        Background="{DynamicResource MainBackgroundBrush}" Margin="0,0,10,0"
                                        Visibility="{Binding KickDropImageUrl, Converter={StaticResource StringToVisibilityConverter}}">
                                    <Image local:ImageEx.SourceUrl="{Binding KickDropImageUrl}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                                <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                           Text="{Binding KickDropName}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>

                            <Grid Margin="0,12,0,0">
                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding KickDropProgress}"/>
                                <TextBlock Text="{Binding KickDropProgress, StringFormat='{}{0}%'}" HorizontalAlignment="Right" Margin="0,-18,0,0"
                                           FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Grid>

                            <!-- Watching + online -->
                            <TextBlock Margin="0,16,0,0" Visibility="{Binding KickWatchedChannel, Converter={StaticResource StringToVisibilityConverter}}">
                                <Run Text="Watching: " Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <Run Text="{Binding KickWatchedChannel}" FontWeight="SemiBold" Foreground="{DynamicResource KickBrush}"/>
                                <Run Text="  "/><Run FontWeight="SemiBold">
                                    <Run.Style>
                                        <Style TargetType="Run">
                                            <Setter Property="Text" Value=""/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding KickStreamOnlineStatus}" Value="online">
                                                    <Setter Property="Text" Value="● online"/><Setter Property="Foreground" Value="#00E676"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding KickStreamOnlineStatus}" Value="offline">
                                                    <Setter Property="Text" Value="● offline"/><Setter Property="Foreground" Value="#FF5252"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Run.Style>
                                </Run>
                            </TextBlock>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0"
                                        Visibility="{Binding KickWatchedChannel, Converter={StaticResource StringToVisibilityConverter}}">
                                <Button Content="Switch" Click="OnSwitchKickStreamerClick" Style="{StaticResource AccentButtonStyle}" Padding="12,6" Margin="0,0,8,0"/>
                                <TextBox x:Name="KickStreamerInput" Width="110" VerticalContentAlignment="Center" ToolTip="Channel name or URL"/>
                                <Button Content="Check" Click="OnCheckKickStreamerClick" Style="{StaticResource AccentButtonStyle}" Padding="12,6" Margin="8,0,0,0"/>
                                <Button Content="Set" Click="OnSetKickStreamerClick" Style="{StaticResource AccentButtonStyle}" Padding="12,6" Margin="8,0,0,0"/>
                            </StackPanel>

                            <TextBlock Text="{Binding KickStreamerCheckResult}" TextWrapping="Wrap" Margin="0,8,0,0"
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Visibility="{Binding KickStreamerCheckResult, Converter={StaticResource StringToVisibilityConverter}}"/>

                            <!-- Also earning -->
                            <StackPanel Margin="0,16,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding KickAlsoMining.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="ALSO EARNING ON THIS CHANNEL" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                                <ItemsControl ItemsSource="{Binding KickAlsoMining}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,6,0,0">
                                                <TextBlock Text="{Binding Name, Mode=OneWay}" FontWeight="SemiBold" FontSize="12"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                <ItemsControl ItemsSource="{Binding Drops}" Margin="8,2,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,3,0,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Border Grid.Column="0" Width="20" Height="20" CornerRadius="3" ClipToBounds="True" Margin="0,0,8,0"
                                                                        Background="{DynamicResource MainBackgroundBrush}" VerticalAlignment="Center">
                                                                    <Image local:ImageEx.SourceUrl="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                                                </Border>
                                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                    <TextBlock TextTrimming="CharacterEllipsis" FontSize="11">
                                                                        <Run Text="{Binding Percent, Mode=OneWay}" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                                                                        <Run Text="% " Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                                                                        <Run Text="{Binding Name, Mode=OneWay}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                                    </TextBlock>
                                                                    <ProgressBar Value="{Binding Percent, Mode=OneWay}" Maximum="100" Height="4" Margin="0,2,0,0"
                                                                                 Foreground="{DynamicResource AccentBrush}" Background="{DynamicResource TrackBrush}"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
