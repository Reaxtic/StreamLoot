<UserControl x:Class="UI.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28">
        <StackPanel>
            <TextBlock Text="Statistics" FontSize="30" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>

            <!-- Summary cards -->
            <UniformGrid Columns="4" Margin="0,0,0,24">
                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" Padding="20" Margin="0,0,12,0"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Watched today" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding WatchedTodayText}" FontSize="26" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" Padding="20" Margin="0,0,12,0"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Last 7 days" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding Watched7DaysText}" FontSize="26" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" Padding="20" Margin="0,0,12,0"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Total watched" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding WatchedTotalText}" FontSize="26" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" Padding="20"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Drops claimed" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding ClaimedCountText}" FontSize="26" FontWeight="Bold"
                                   Foreground="#22C55E" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Claim history -->
            <TextBlock Text="Claim history" FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>

            <TextBlock Text="No drops claimed yet — they will show up here."
                       Foreground="{DynamicResource TextMutedBrush}" FontSize="13"
                       Visibility="{Binding NoClaimsVisibility}"/>

            <ItemsControl ItemsSource="{Binding Claims}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="14,10"
                                Margin="0,0,0,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding When, StringFormat='dd MMM yyyy • HH:mm'}"
                                           Foreground="{DynamicResource TextMutedBrush}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Platform}"
                                           Foreground="{DynamicResource AccentBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding Campaign}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="3" Text="{Binding Reward}"
                                           Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
