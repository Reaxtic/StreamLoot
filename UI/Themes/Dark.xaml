<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Themes/Colors.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Modern dark palette (Stream Loot) -->
    <SolidColorBrush x:Key="MainBackgroundBrush"                      Color="#0E1014"/>
    <SolidColorBrush x:Key="CardBackgroundBrush"                      Color="#181C22"/>
    <SolidColorBrush x:Key="CardElevatedBrush"                        Color="#1F242C"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush"                    Color="#0E1014"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush"                   Color="#14181E"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"                         Color="#F4F6F8"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"                       Color="#9BA3AF"/>
    <SolidColorBrush x:Key="TextMutedBrush"                           Color="#5C6470"/>
    <SolidColorBrush x:Key="BorderBrush"                              Color="#242932"/>
    <SolidColorBrush x:Key="HoverBrush"                               Color="#10333D"/>
    <SolidColorBrush x:Key="PressedBrush"                             Color="#0E2A32"/>
    <SolidColorBrush x:Key="SidebarHoverBrush"                        Color="#1B212A"/>
    <SolidColorBrush x:Key="TitleBarButtonHoverBrush"                 Color="#20262F"/>
    <SolidColorBrush x:Key="NavActiveBackgroundBrush"                 Color="#15303A"/>
    <SolidColorBrush x:Key="TrackBrush"                               Color="#262B33"/>
    <SolidColorBrush x:Key="ComboBoxItem.SelectedBackground"          Color="#0E2A32"/>
    <SolidColorBrush x:Key="ComboBoxItem.SelectedForeground"          Color="#22D3EE"/>
    <SolidColorBrush x:Key="ComboBoxItem.SelectedHoverBackground"     Color="#10333D"/>

    <Color x:Key="AccentColor">#22D3EE</Color>
    <Color x:Key="SecondaryAccentColor">#3BAFFF</Color>
    <Color x:Key="TextPrimaryColor">#F4F6F8</Color>
    <Color x:Key="CardBackgroundColor">#181C22</Color>
    
    <SolidColorBrush x:Key="AccentBrush"              Color="#22D3EE"/>
    <SolidColorBrush x:Key="SecondaryAccentBrush"     Color="#3BAFFF"/>
</ResourceDictionary>