<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- PLATFORM COLORS -->
    <Color x:Key="TwitchPurple">#9146FF</Color>
    <Color x:Key="KickGreen">#5FF41C</Color>
    <SolidColorBrush x:Key="TwitchBrush" Color="{StaticResource TwitchPurple}"/>
    <SolidColorBrush x:Key="KickBrush"   Color="{StaticResource KickGreen}"/>

    <!-- THESE WILL BE OVERRIDDEN BY Dark/Light -->
    <SolidColorBrush x:Key="MainBackgroundBrush"      Color="#000000"/>
    <SolidColorBrush x:Key="CardBackgroundBrush"      Color="#000000"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush"    Color="#000000"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"       Color="#CCCCCC"/>
    <SolidColorBrush x:Key="TextMutedBrush"           Color="#AAAAAA"/>
    <SolidColorBrush x:Key="BorderBrush"              Color="#404040"/>
    <SolidColorBrush x:Key="HoverBrush"               Color="#3A3A3A"/>
    <SolidColorBrush x:Key="PressedBrush"             Color="#2F2F2F"/>
    <!-- New shell keys (overridden per theme) -->
    <SolidColorBrush x:Key="SidebarBackgroundBrush"   Color="#0A0A0A"/>
    <SolidColorBrush x:Key="CardElevatedBrush"        Color="#1F1F1F"/>
    <SolidColorBrush x:Key="NavActiveBackgroundBrush" Color="#15303A"/>
    <SolidColorBrush x:Key="TrackBrush"               Color="#2A2A2A"/>

    <!-- ACCENT / BRAND -->
    <Color x:Key="AccentColor">#22D3EE</Color>
    <Color x:Key="SecondaryAccentColor">#3BAFFF</Color>
    <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
    <Color x:Key="CardBackgroundColor">#000000</Color>
    <SolidColorBrush x:Key="AccentBrush"             Color="#22D3EE"/>
    <SolidColorBrush x:Key="SecondaryAccentBrush"    Color="#3BAFFF"/>
</ResourceDictionary>